# INDmoney MCP — optional override (defaults to official URL in code if unset)
# Official: https://mcp.indmoney.com/mcp — see https://www.indmoney.com/mcp
# INDMONEY_MCP_URL=https://mcp.indmoney.com/mcp

# Optional Bearer token for JSON-RPC POSTs (see README: live data / proxy). Unset = no Authorization header.
# INDMONEY_MCP_BEARER_TOKEN=

# SQLite URL (default matches backend/app/config.py)
# DATABASE_URL=sqlite+aiosqlite:///./data/truewealth.db

# CORS for local Next dev server (comma-separated; used for API fetch + allowlist for OAuth return_base)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OAuth callback must match this origin (INDmoney redirects the browser here after login).
# TRUEWEALTH_API_PUBLIC_BASE=http://127.0.0.1:8000

# After OAuth, the API redirects the browser here (query indmoney_oauth=ok|error).
# FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/today

# Optional: issuer for /.well-known/oauth-authorization-server (default mcp.indmoney.com).
# INDMONEY_OAUTH_ISSUER=https://mcp.indmoney.com

# Optional: display name at dynamic client registration.
# INDMONEY_OAUTH_CLIENT_NAME=True Wealth

# Optional: static USDINR fallback when live FX fetch is unavailable (default 94.61 in code)
# USDINR_RATE=94.61

# Optional: live USD/INR JSON endpoint (Frankfurter default in code; cached in SQLite)
# FX_LIVE_URL=https://api.frankfurter.dev/v1/latest?from=USD&to=INR

# Optional: require X-API-Key or Bearer on /api/* (health + OAuth exempt). Unset = open on localhost.
# TRUEWEALTH_API_KEY=

# Optional: OHLC day-move proxy depth per price refresh (default 5)
# OHLC_ENRICH_MAX=5

# Optional: cap MCP fund-detail calls per holdings refresh (avoids blocking /api/portfolio on many MFs)
# MF_LAB_MAX_MCP_CALLS=8

# Optional: log MCP raw row key names (no values) after each holdings fetch
# TW_HOLDINGS_RAW_PREVIEW=1

# Optional tuning (defaults in Settings)
# CONCENTRATION_THRESHOLD_PCT=15
# PRICE_REFRESH_SEC=10
# HOLDINGS_REFRESH_SEC=120
